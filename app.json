{
  "expo": {
    "name": "forgot-something",
    "slug": "forgot-something",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/forgotSomethingLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/forgotSomethingLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.forgot-something"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/forgotSomethingLogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/forgotSomethingLogo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
